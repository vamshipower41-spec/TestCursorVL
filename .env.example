# Upstox API credentials
# Obtain your daily access token from Upstox and paste it here before market opens
UPSTOX_ACCESS_TOKEN=your_daily_access_token_here

# Telegram alerts (optional)
# Message @BotFather on Telegram -> /newbot -> get your bot token
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
# Message your bot, then visit https://api.telegram.org/bot<TOKEN>/getUpdates to get chat_id
TELEGRAM_CHAT_ID=your_telegram_chat_id_here
